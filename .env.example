APP_NAME=Joordak
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://joordak.shop

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fa_IR

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=joordak
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

VITE_APP_NAME=Joordak

# Liara object storage (recommended: separate bucket from Bluesheep)
LIARA_ACCESS_KEY=
LIARA_SECRET_KEY=
LIARA_REGION=us-east-1
LIARA_BUCKET_NAME=
LIARA_ENDPOINT=
LIARA_USE_PATH_STYLE_ENDPOINT=false
LIARA_DOMAIN=

# SMS.ir OTP
SMS_API_KEY=
SMS_TEMPLATE_ID=
SMS_OTP_PARAMETER_NAME=Code

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@joordak.shop
MAIL_FROM_NAME="${APP_NAME}"
